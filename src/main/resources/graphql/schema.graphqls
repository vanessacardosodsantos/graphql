type Query {
  bookById(id: ID!): Book
  authorById(id: ID!): Author
  getBooks(filter: BooksFilter): [Book!]!
}

type Book {
  id: ID!
  name: String
  pageCount: Int
  author: Author
}

type Author {
  id: ID!
  firstName: String
  lastName: String
  publishedBooks: [Book!]!
}

enum Genre {
  ACTION
  ADVENTURE
  COMEDY
  TERROR
  TECHNICAL
}

input BooksFilter {
    genres: [Genre],
    maxPages: Int
}